{
  "name": "@honorclaw/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "honorclaw": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@honorclaw/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "js-yaml": "^4.1.1",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
