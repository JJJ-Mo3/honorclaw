# HonorClaw Environment Variables
# Copy to .env and fill in values. NEVER commit .env files.

# ── Authentication (REQUIRED) ────────────────────────────────────────────
# JWT signing secret (min 32 characters)
# Generate: openssl rand -base64 48
JWT_SECRET=

# Session cookie signing secret
# Generate: openssl rand -base64 32
SESSION_COOKIE_SECRET=

# Master encryption key for secrets store (base64-encoded 32 bytes)
# Generate: openssl rand -base64 32
HONORCLAW_MASTER_KEY=

# ── Database ─────────────────────────────────────────────────────────────
# Only needed for external PostgreSQL; embedded uses Unix socket.
# These override honorclaw.yaml database/redis settings when set.
# POSTGRES_URL=postgresql://honorclaw:honorclaw@localhost:5432/honorclaw
# POSTGRES_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────
# Only needed for external Redis; embedded uses Unix socket.
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ── LLM Providers ───────────────────────────────────────────────────────
# Ollama is the default (no key needed). Uncomment and set API keys
# for any frontier providers you want to enable.

# Ollama (default — no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic Claude (claude-sonnet-4-20250514, claude-haiku-4-5-20251001)
# ANTHROPIC_API_KEY=

# AWS Bedrock (Claude via IAM — alternative to direct Anthropic API key)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Google Vertex AI (Claude via GCP — alternative to direct Anthropic API key)
# Set to the raw JSON content of your service account key:
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# OpenAI (gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
# OPENAI_API_KEY=

# Azure OpenAI (alternative to OpenAI direct)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=

# Google Gemini (gemini-1.5-pro, gemini-1.5-flash)
# GOOGLE_AI_API_KEY=

# Mistral (mistral-large-latest, mistral-medium-latest)
# MISTRAL_API_KEY=

# ── API ──────────────────────────────────────────────────────────────────
# API key for CLI / M2M access
# HONORCLAW_API_KEY=

# Allow webhooks over HTTP (HTTPS enforced by default)
# ALLOW_HTTP_WEBHOOKS=false

# ── Security ─────────────────────────────────────────────────────────────
# Agent isolation mode: dev | namespace | full
AGENT_ISOLATION_MODE=namespace

# Environment: development | production
NODE_ENV=development

# ── Logging & Observability ──────────────────────────────────────────────
LOG_LEVEL=info

# OpenTelemetry OTLP endpoints (optional)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
