# HonorClaw Environment Variables
# Copy to .env and fill in values. NEVER commit .env files.

# Master encryption key (base64-encoded 32 bytes)
# Generate: openssl rand -base64 32
HONORCLAW_MASTER_KEY=

# Database (only needed for external PostgreSQL; embedded uses Unix socket)
# POSTGRES_URL=postgresql://user:password@host:5432/honorclaw

# Redis (only needed for external Redis; embedded uses Unix socket)
# REDIS_URL=redis://:password@host:6379/0

# LLM Provider API Keys (store via: honorclaw secrets set llm/anthropic-key <key>)
# Do NOT put API keys here — use the secrets store instead.

# Ollama (default — no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Security mode: dev | namespace | full
AGENT_ISOLATION_MODE=namespace

# Logging
LOG_LEVEL=info
