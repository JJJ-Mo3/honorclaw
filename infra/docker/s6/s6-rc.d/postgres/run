#!/bin/sh
if [ -f /tmp/skip-embedded-postgres ]; then
  exec sleep infinity
fi

PGDATA=/data/postgres
if [ ! -d "$PGDATA/PG_VERSION" ]; then
  mkdir -p "$PGDATA"
  chown -R postgres:postgres "$PGDATA"
  su-exec postgres initdb -D "$PGDATA" --auth-local=trust --auth-host=md5
fi

# Start Postgres temporarily to create the honorclaw database
su-exec postgres pg_ctl -D "$PGDATA" -o "-c listen_addresses='' -c unix_socket_directories='/var/run/postgresql'" -w start
su-exec postgres psql -h /var/run/postgresql -c "SELECT 1 FROM pg_database WHERE datname = 'honorclaw'" | grep -q 1 || \
  su-exec postgres createdb -h /var/run/postgresql honorclaw
# Install required extensions
su-exec postgres psql -h /var/run/postgresql -d honorclaw -c "CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\";" 2>/dev/null || true
su-exec postgres psql -h /var/run/postgresql -d honorclaw -c "CREATE EXTENSION IF NOT EXISTS \"pgcrypto\";" 2>/dev/null || true
su-exec postgres psql -h /var/run/postgresql -d honorclaw -c "CREATE EXTENSION IF NOT EXISTS \"vector\";" 2>/dev/null || true
su-exec postgres pg_ctl -D "$PGDATA" -w stop

exec su-exec postgres postgres -D "$PGDATA" \
  -c listen_addresses='' \
  -c unix_socket_directories='/var/run/postgresql' \
  -c shared_preload_libraries='' \
  -c log_destination=stderr \
  -c logging_collector=off
