#!/bin/sh
if [ -f /tmp/skip-embedded-redis ]; then
  exec sleep infinity
fi

mkdir -p /data/redis /var/run/redis

exec redis-server \
  --unixsocket /var/run/redis/redis.sock \
  --unixsocketperm 777 \
  --port 0 \
  --requirepass "${REDIS_PASSWORD:-honorclaw}" \
  --maxmemory 512mb \
  --maxmemory-policy allkeys-lru \
  --appendonly yes \
  --dir /data/redis
